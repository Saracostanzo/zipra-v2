# ═══════════════════════════════════════════════
# ZIPRA — Variabili d'ambiente
# Copia in .env.local e compila tutti i valori
# ═══════════════════════════════════════════════

# ─── Supabase ────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Solo server-side, mai esporre al client

# ─── Anthropic (Claude AI) ──────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Voyage AI (embeddings per RAG) ─────────
# Registrati su https://www.voyageai.com (free tier disponibile)
VOYAGE_API_KEY=pa-...

# ─── Resend (email transazionali) ───────────
# Registrati su https://resend.com (free: 3000 email/mese)
RESEND_API_KEY=re_...

# ─── Twilio (SMS) ────────────────────────────
# Opzionale — solo se vuoi notifiche SMS
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+39...

# ─── Stripe (pagamenti) ─────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Vercel (deploy siti vetrina) ───────────
# Ottieni il token da https://vercel.com/account/tokens
VERCEL_TOKEN=...

# ─── Replicate (generazione logo AI) ────────
# Registrati su https://replicate.com (pay-per-use)
REPLICATE_API_TOKEN=r8_...

# ─── App ─────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
CRON_SECRET=scegli-una-stringa-segreta-lunga   # Per proteggere il cron job

# ─── Stripe Price IDs ─────────────────────────────────────────────
# Crea i prodotti su stripe.com → Products → Add product
# Poi copia i Price ID (formato: price_xxxxxxxxxxxx)
STRIPE_PRICE_STARTER=price_...      # €49 one-time
STRIPE_PRICE_BASE=price_...         # €149 one-time
STRIPE_PRICE_PRO=price_...          # €299 one-time
STRIPE_PRICE_MANTENIMENTO=price_... # €29/mese recurring
STRIPE_PRICE_BUSINESS=price_...     # €199/mese recurring

# ─── Yousign (firma digitale) ─────────────────────────────────────────────────
# Registrati su https://yousign.com → Developers → API Keys
# SANDBOX = true per i test, false per la produzione
YOUSIGN_API_KEY=...
YOUSIGN_SANDBOX=true
# Webhook secret — configuralo su Yousign → Webhooks → Add endpoint
# URL webhook: https://tuodominio.it/api/firma/webhook
YOUSIGN_WEBHOOK_SECRET=...

# ─── Stripe aggiuntivi (Business Pro) ────────────────────────────────────────
STRIPE_PRICE_BUSINESS_PRO=price_...    # €299/mese — Business Pro siti illimitati

# ─── Google Business Profile API ─────────────────────────────────────────────
# Setup: console.cloud.google.com → crea progetto → abilita "Business Profile API"
# → crea Service Account → scarica JSON credenziali
# Poi richiedi accesso API su: https://developers.google.com/my-business/content/prereqs
GOOGLE_PROJECT_ID=zipra-prod
GOOGLE_CLIENT_EMAIL=zipra-service@zipra-prod.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Google Workspace (per creare account Google dedicati per i clienti)
# Opzionale — se non configurato, le credenziali sono generate ma l'account va creato a mano
GOOGLE_ADMIN_EMAIL=admin@tuodominio.com
GOOGLE_ADMIN_DOMAIN=clienti-zipra.it    # dominio dedicato per i clienti
